# Database — MongoDB connection string.
# Local:    mongodb://localhost:27017/aurora
# Atlas:    mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/aurora
DATABASE_URL="mongodb://localhost:27017/aurora"

# Auth secrets — generate your own with: openssl rand -base64 32
# (The app runs with dev fallbacks if these are absent, but ALWAYS set them
#  in production.)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
