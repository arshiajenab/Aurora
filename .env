# Database — relative path so it works on any OS (Linux/macOS/Windows).
# Prisma resolves this relative to the prisma/schema.prisma location.
DATABASE_URL="file:./db/custom.db"

# Auth secrets — generate your own with: openssl rand -base64 32
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
